{
  "name": "glyph",
  "version": "1.0.0",
  "description": "代码即艺术。Glyph 将源代码转化为具有审美意图的抽象画。",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx server.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "tsx server.ts"
  },
  "keywords": [
    "art",
    "code",
    "svg",
    "generative-art",
    "deepseek"
  ],
  "license": "MIT",
  "dependencies": {
    "dompurify": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsdom": "^25.0.0",
    "openai": "^4.70.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
